# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL credentials
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=seismic_pass_2024
POSTGRES_DB=seismic_db

# Full connection URI (must match the credentials above)
DATABASE_URL=postgresql://postgres_user:change_me_before_deploying@postgres_db:5432/seismic_db

# Pipeline tunables
MIN_MAGNITUDE=2.5
LOOKBACK_DAYS=1

# Slack Incoming Webhook URL (leave blank to disable alerts)
SLACK_WEBHOOK_URL=
